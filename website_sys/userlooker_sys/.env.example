# ============================================================
#              USERLOOKER ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values
# Lines starting with # are comments
# Variables marked [OPTIONAL] have default values
# ============================================================


# ============================================================
#         PART 1: WEBSITE & API (Production Server)
# ============================================================
# These are needed to run the web application (frontend + backend)

# --- MongoDB Connection ---
MONGO_URI=mongodb://localhost:27017                    # [OPTIONAL] MongoDB connection string
DB_NAME=discord_data                                   # [OPTIONAL] Database name
MESSAGE_DB_NAME=message_db                             # [OPTIONAL] Message database name

# --- Discord OAuth2 (Required for admin login) ---
DISCORD_CLIENT_ID=your_discord_client_id               # From Discord Developer Portal
DISCORD_CLIENT_SECRET=your_discord_client_secret       # From Discord Developer Portal
DISCORD_REDIRECT_URI=http://localhost:8001/auth/discord/callback  # [OPTIONAL] OAuth callback URL

# --- Admin Access ---
ADMIN_DISCORD_IDS=123456789012345678                   # Comma-separated Discord User IDs allowed as admin
                                                       # Example: ADMIN_DISCORD_IDS=123456789,987654321

# --- JWT Authentication ---
JWT_SECRET_KEY=your-super-secret-key-change-this       # IMPORTANT: Use a strong random string (64+ chars)
ACCESS_TOKEN_EXPIRE_MINUTES=60                         # [OPTIONAL] Access token lifetime in minutes
REFRESH_TOKEN_EXPIRE_DAYS=7                            # [OPTIONAL] Refresh token lifetime in days

# --- Frontend URL ---
FRONTEND_URL=http://localhost:5173                     # [OPTIONAL] URL where frontend is hosted
                                                       # Production example: https://userlooker.example.com

# --- Rate Limiting (Advanced) ---
# REDIS_URL=redis://localhost:6379                     # [OPTIONAL] Redis URL for distributed rate limiting
                                                       # If not set, uses in-memory storage

# --- CORS (Production Security) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000  # [OPTIONAL] Comma-separated allowed origins
                                                          # Production: CORS_ORIGINS=https://yourdomain.com


# ============================================================
#         PART 2: EXTRACTOR (Extraction Server/Machine)
# ============================================================
# These are needed to run the data extraction script (dce_extractor.py)
# Can be on the same machine or a separate extraction server

# --- MongoDB Connection (for Extractor) ---
MONGO_HOST=localhost                                   # [OPTIONAL] MongoDB host
MONGO_PORT=27017                                       # [OPTIONAL] MongoDB port
DB_NAME=discord_data                                   # [OPTIONAL] Database name (same as above)

# --- Rate Limiting (Prevents MongoDB overload) ---
MONGO_BATCH_SIZE=50                                    # [OPTIONAL] Users per batch (default: 100)
MONGO_BATCH_DELAY=0.5                                  # [OPTIONAL] Seconds between batches (default: 0.5)
MONGO_MSG_BATCH_SIZE=25                                # [OPTIONAL] Messages per batch (default: 50)
MONGO_MSG_BATCH_DELAY=0.5                              # [OPTIONAL] Seconds between message batches (default: 0.3)

# Recommended values for low-spec servers (2 core, 4GB RAM):
#   MONGO_BATCH_SIZE=50
#   MONGO_BATCH_DELAY=0.5
#   MONGO_MSG_BATCH_SIZE=25
#   MONGO_MSG_BATCH_DELAY=0.5

# --- Backblaze B2 (Only if using --b2 flag) ---
# B2_KEY_ID=your_b2_key_id                             # [OPTIONAL] Backblaze B2 Key ID
# B2_APP_KEY=your_b2_app_key                           # [OPTIONAL] Backblaze B2 Application Key
# B2_ENDPOINT=https://s3.us-west-000.backblazeb2.com   # [OPTIONAL] B2 S3-compatible endpoint

# --- Gemini AI (Only for unknown_analyzer.py) ---
# GEMINI_API_KEY=your_gemini_api_key                   # [OPTIONAL] Google Gemini API key for analysis


# ============================================================
#                    QUICK SETUP GUIDE
# ============================================================
#
# FOR WEBSITE/API SERVER:
#   1. Set DISCORD_CLIENT_ID and DISCORD_CLIENT_SECRET
#   2. Set ADMIN_DISCORD_IDS to your Discord User ID
#   3. Change JWT_SECRET_KEY to a random string
#   4. Update FRONTEND_URL and DISCORD_REDIRECT_URI for production
#
# FOR EXTRACTION SERVER (if separate):
#   1. Set MONGO_HOST to your main server's IP
#   2. Adjust MONGO_BATCH_SIZE and delays based on server capacity
#   3. Set B2 credentials if extracting from Backblaze B2
#
# ============================================================
